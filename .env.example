# VAEL – Environment Variables
# Copy to .env and fill in values (all keys are optional; the pipeline degrades gracefully)

# ── NVD (National Vulnerability Database) ─────────────────────────────────────
# Free API key at https://nvd.nist.gov/developers/request-an-api-key
# Without this, NVD requests are rate-limited to 5 req/30s (still works, just slower)
NVD_API_KEY=

# ── GitHub (PoC Harvesting) ────────────────────────────────────────────────────
# Personal Access Token: https://github.com/settings/tokens
# Needs: public_repo (read-only) scope
# Without this, GitHub search is rate-limited to 10 req/min unauthenticated
GITHUB_TOKEN=

# ── Google Gemini (AI Verdict) ─────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
# Model: gemini-2.5-flash (default). Without this, the pipeline uses deterministic verdicts.
GEMINI_API_KEY=

# ── Optional: override the Gemini model ───────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash

# ── VulnCheck (Threat Actor / Ransomware Attribution) ─────────────────────────
# Free community key at https://vulncheck.com/register
# Enables threat actor (APT) and ransomware group attribution per CVE via the
# /v3/index/initial-access and /v3/index/ransomware endpoints.
# Without this key, threat intel fields are left empty (pipeline still works).
VULNCHECK_API_KEY=

# ── Shodan (Internet Exposure – Stage 4) ──────────────────────────────────────
# Free tier at https://account.shodan.io/register (1 search credit per query)
# Used to count internet-exposed hosts running the vulnerable software.
SHODAN_API_KEY=

# ── Censys (Internet Exposure – Stage 4) ──────────────────────────────────────
# Free tier at https://accounts.censys.io/register (250 queries/month)
CENSYS_API_ID=
CENSYS_API_SECRET=

# ── FOFA (Internet Exposure – Stage 4) ───────────────────────────────────────
# Free registration at https://fofa.info/
# Adds Asian/Middle East infrastructure coverage to Stage 4 exposure analysis.
# Both FOFA_API_KEY and FOFA_EMAIL must be set together.
FOFA_API_KEY=
FOFA_EMAIL=

# ── ZoomEye (Internet Exposure – Stage 4) ────────────────────────────────────
# Free registration at https://www.zoomeye.ai/
# Adds global coverage complementary to Shodan in Stage 4 exposure analysis.
ZOOMEYE_API_KEY=

# ── Rapid7 AttackerKB (Stage 1 CVE Discovery) ─────────────────────────────────
# Free key at https://attackerkb.com/user/register
# Adds community exploitability scores and exploitation status from Rapid7 researchers.
# Without this key, AttackerKB is silently skipped (pipeline still works).
ATTACKERKB_API_KEY=

# ── Pipeline tunables ─────────────────────────────────────────────────────────
# Override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Maximum CVEs fetched from NVD per query (default: 200)
# MAX_NVD_RESULTS=200

# Maximum CVEs fetched from OSV per query (default: 100)
# MAX_OSV_RESULTS=100

# Top-N priority CVEs passed to the Stage 3 PoC harvester (default: 10)
# STAGE3_TOP_N=10

# Set to false to run the pipeline fully offline (uses cached data only)
# ALLOW_NETWORK=true

# ── Server / deployment ────────────────────────────────────────────────────────
# Number of gunicorn worker processes (default: 2; increase for high concurrency)
VAEL_WORKERS=2

# Log level: debug | info | warning | error
LOG_LEVEL=warning

# Set to true to hide /docs and /redoc in production
DISABLE_DOCS=false

# Comma-separated allowed CORS origins. Use * to allow all (default, fine for internal tools).
# For public deployments: ALLOW_ORIGINS=https://yourdomain.com
ALLOW_ORIGINS=*

# Public port exposed by nginx (default 80)
PORT=80
